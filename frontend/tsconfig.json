{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "composite": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2022",
    "types": ["node", "react", "react-dom"]
  },
  "include": ["src"]
}
